# Default: normalize text files to LF in-repo
* text=auto eol=lf

# Shell and config files stay LF
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf
*.bats text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.conf text eol=lf

# Keep Windows PowerShell scripts as CRLF for native editing/interop
*.ps1 text eol=crlf
*.psm1 text eol=crlf
*.psd1 text eol=crlf

# Common binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.woff binary
*.woff2 binary
