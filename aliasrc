############################################
# SYSTEM — OS-SPECIFIC
############################################

# --- Debian / Ubuntu / WSL ---
if command -v apt >/dev/null 2>&1; then
    # FIX: full-upgrade instead of upgrade.
    # 'apt upgrade' holds back packages that need new or removed deps.
    # 'apt full-upgrade' handles those correctly — right choice for Debian.
    alias apt-up='sudo apt update && sudo apt full-upgrade -y && sudo apt autoremove -y'
    alias apt-search='apt search'
    alias apt-show='apt show'
    alias apt-list='apt list --installed'
fi

# FIX: update-grub exists on Debian as well as Arch.
# Guard it by checking the binary — correct for both systems.
if command -v update-grub >/dev/null 2>&1; then
    alias update-grub='sudo update-grub'
fi

# --- macOS ---
if [[ "$OSTYPE" == darwin* ]]; then
    alias brewup='brew update && brew upgrade && brew cleanup'
    alias brewinfo='brew info'
    alias brewlist='brew list'
    # Clipboard shortcuts (macOS only)
    alias pbp='pbpaste'
    alias pbc='pbcopy'
    # Open current directory in Finder
    alias finder='open .'
fi


############################################
# VPN (OpenVPN via systemctl)
# systemctl is available on Debian/WSL but NOT on macOS
############################################

if command -v systemctl >/dev/null 2>&1; then
    alias gds-start='sudo systemctl start openvpn-client@gds'
    alias gds-stop='sudo systemctl stop openvpn-client@gds'
    alias gds-status='sudo systemctl status openvpn-client@gds'
fi


############################################
# MISC TOOLS (machine-specific, guarded)
############################################

if [ -x '/opt/LBRY/resources/static/daemon/lbrynet' ]; then
    alias lbrynet='/opt/LBRY/resources/static/daemon/lbrynet'
fi
